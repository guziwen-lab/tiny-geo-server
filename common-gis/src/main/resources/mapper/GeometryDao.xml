<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supermap.dao.GeometryDao">

    <update id="normalizeGeometry">
        CREATE TABLE ${tempTableName} AS
        SELECT
        <foreach collection="columns" item="col" separator="," close=",">
            #{col.name}
        </foreach>
        ST_Multi(ST_CollectionExtract(ST_MakeValid(geom), #{dimension})) AS geom
        FROM ${table}
    </update>
</mapper>
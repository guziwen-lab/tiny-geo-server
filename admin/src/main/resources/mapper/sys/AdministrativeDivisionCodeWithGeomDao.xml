<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supermap.modules.sys.dao.AdministrativeDivisionCodeWithGeomDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.supermap.modules.sys.entity.AdministrativeDivisionCodeWithGeomEntity" id="administrativeDivisionCodeWithGeomMap">
        <result property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="pcode" column="pcode"/>
        <result property="name" column="name"/>
        <result property="level" column="level"/>
        <result property="geom" column="geom"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <update id="setGeom">
        update sys_administrative_division_code_with_geom
        set geom = ST_GeomFromGeoJSON(#{geoJSON})
        where code = #{code}
    </update>
</mapper>